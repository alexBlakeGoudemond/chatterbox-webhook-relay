{
    "type": "message",
    "attachments": [
        {
            "contentType": "application/vnd.microsoft.card.adaptive",
            "content": {
                "type": "AdaptiveCard",
                "msteams": {
                    "width": "Full"
                },
                "body": [
                    {
                        "type": "TextBlock",
                        "text": "📢 ${displayName} for ${repositoryName}",
                        "wrap": true
                    },
                    {
                        "type": "TextBlock",
                        "text": "⁉️ Details: [${urlDisplayText}](${url}) created by ${senderName}",
                        "wrap": true
                    }
                ],
                "$schema": "http://adaptivecards.io/schemas/adaptive-card.json",
                "version": "1.0"
            }
        }
    ]
}